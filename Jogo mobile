<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Neon Colony Online</title>
<style>
body{margin:0;background:#000;color:#0ff;font-family:Arial;overflow:hidden}
#menu{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%)}
#hud{position:absolute;top:10px;left:10px}
input,button{padding:10px;margin:5px}
</style>
</head>
<body>

<div id="menu">
<input id="user" placeholder="usuario">
<input id="pass" placeholder="senha" type="password">
<button onclick="login()">Login</button>
<button onclick="register()">Registrar</button>
</div>

<div id="hud" style="display:none">
💰 <span id="money">0</span>
</div>

<script src="https://cdn.jsdelivr.net/npm/three@0.160/build/three.min.js"></script>

<script>
let socket;
let scene,camera,renderer,player;
let keys={},vel={x:0,z:0};
let players={},meshes={};
let money=0;

// ===== LOGIN =====
function login(){
 socket = new WebSocket("ws://localhost:3001");

 socket.onopen = ()=>{
  socket.send(JSON.stringify({
    type:"login",
    user:user.value,
    pass:pass.value
  }));
 };

 socket.onmessage = e=>{
  let data = JSON.parse(e.data);

  if(data.type==="login_ok"){
    money = data.money;
    startGame();
  }

  if(data.type==="register_ok"){
    alert("Conta criada!");
  }

  if(data.type==="update"){
    players = data.players;
  }
 };
}

// ===== REGISTER =====
function register(){
 socket = new WebSocket("ws://localhost:3001");

 socket.onopen = ()=>{
  socket.send(JSON.stringify({
    type:"register",
    user:user.value,
    pass:pass.value
  }));
 };
}

// ===== START GAME =====
function startGame(){
 document.getElementById("menu").style.display="none";
 document.getElementById("hud").style.display="block";

 scene = new THREE.Scene();
 camera = new THREE.PerspectiveCamera(75,innerWidth/innerHeight,0.1,1000);
 renderer = new THREE.WebGLRenderer();
 renderer.setSize(innerWidth,innerHeight);
 document.body.appendChild(renderer.domElement);

 let light = new THREE.DirectionalLight(0xffffff,1);
 light.position.set(10,20,10);
 scene.add(light);

 player = new THREE.Mesh(
  new THREE.BoxGeometry(1,2,1),
  new THREE.MeshStandardMaterial({color:0x00ffff})
 );
 player.position.y=1;
 scene.add(player);

 let floor = new THREE.Mesh(
  new THREE.PlaneGeometry(500,500),
  new THREE.MeshStandardMaterial({color:0x111})
 );
 floor.rotation.x=-Math.PI/2;
 scene.add(floor);

 for(let i=0;i<200;i++){
  let b=new THREE.Mesh(
   new THREE.BoxGeometry(5,Math.random()*10+5,5),
   new THREE.MeshStandardMaterial({color:0x222})
  );
  b.position.set((Math.random()-0.5)*200,2,(Math.random()-0.5)*200);
  scene.add(b);
 }

 window.onkeydown=e=>keys[e.key]=true;
 window.onkeyup=e=>keys[e.key]=false;

 loop();
}

// ===== UPDATE =====
function update(){

 if(keys["w"]) vel.z-=0.05;
 if(keys["s"]) vel.z+=0.05;
 if(keys["a"]) vel.x-=0.05;
 if(keys["d"]) vel.x+=0.05;

 vel.x*=0.9;
 vel.z*=0.9;

 player.position.x+=vel.x;
 player.position.z+=vel.z;

 camera.position.set(player.position.x,5,player.position.z+8);
 camera.lookAt(player.position);

 // enviar pro servidor
 socket.send(JSON.stringify({
  type:"move",
  x:player.position.x,
  z:player.position.z
 }));

 // render outros players
 for(let id in players){

  if(!meshes[id]){
   let m=new THREE.Mesh(
    new THREE.BoxGeometry(1,2,1),
    new THREE.MeshStandardMaterial({color:0xff00ff})
   );
   scene.add(m);
   meshes[id]=m;
  }

  meshes[id].position.set(players[id].x,1,players[id].z);
 }

 document.getElementById("money").innerText=money;
}

// ===== LOOP =====
function loop(){
 requestAnimationFrame(loop);
 update();
 renderer.render(scene,camera);
}
</script>
</body>
</html>index.html